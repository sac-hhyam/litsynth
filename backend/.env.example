# ── NVIDIA NIM / NeMoClaw ────────────────────────────────────────────────────
# Get your key from: https://build.nvidia.com  (free tier available)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NIM inference base URL
# Default: NVIDIA's hosted NIM catalogue
# On Brev with a local NIM container, replace with: http://localhost:8000/v1
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Model to use — must be available on your NIM endpoint
# Options (NVIDIA hosted): meta/llama-3.1-70b-instruct
#                           mistralai/mistral-7b-instruct-v0.3
#                           microsoft/phi-3-mini-128k-instruct
NIM_MODEL=meta/llama-3.1-70b-instruct

# ── Semantic Scholar ─────────────────────────────────────────────────────────
# Get a free API key at: https://www.semanticscholar.org/product/api
# Rate limit with key: 1 req/s (enough for LitSynth — 1 call per task)
# Without key: unauthenticated tier, heavily throttled — not recommended
S2_API_KEY=your-semantic-scholar-api-key-here

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, zero setup):
DATABASE_URL=sqlite:///./litsynth.db

# ── Agent tuning ─────────────────────────────────────────────────────────────
MAX_SYNTHESIS_TOKENS=1024
LLM_TEMPERATURE=0.4

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── NeMoClaw Discord Bot ──────────────────────────────────────────────────────
# Get your bot token from: https://discord.com/developers/applications
# (Bot > Reset Token)
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# NeMoClaw sandbox name (default matches the onboarded sandbox)
NEMOCLAW_SANDBOX=lit-synth-sandbox

# Seconds to wait for sandbox exec before timing out
SYNTHESIS_TIMEOUT=120
